  <diagram name="Page-1" id="1Xm6OeRqyXARuXSqNXmK">
    <mxGraphModel dx="2910" dy="1142" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="qWQqwVkxpHxcz5jvb_I_-1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="&lt;div&gt;URL Shortner&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="120" x="30" y="20" as="geometry" />
        </mxCell>
        <mxCell id="qWQqwVkxpHxcz5jvb_I_-2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Functional Requirements:&lt;br&gt;&lt;br&gt;&lt;div&gt;1. Paste the url and get shortened url back.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;2. If you paste the short URL then you should be able to get the long and vice-versa.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;3. No authentication req for now&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;4. The URL should be having an expiry. 6 Months of no use.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="300" width="120" x="190" y="20" as="geometry" />
        </mxCell>
        <mxCell id="qWQqwVkxpHxcz5jvb_I_-3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Non-Functional Requirements:&lt;br&gt;&lt;br&gt;&lt;div&gt;1. 100 URL&#39;s can be created/sec&amp;nbsp;&lt;/div&gt;&lt;div&gt;2. 1 Million reads per second&lt;/div&gt;&lt;div&gt;3. System should be highly available&lt;/div&gt;&lt;div&gt;5. Eventually Consistent&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="190" width="120" x="340" y="20" as="geometry" />
        </mxCell>
        <mxCell id="qWQqwVkxpHxcz5jvb_I_-6" edge="1" parent="1" source="qWQqwVkxpHxcz5jvb_I_-4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;">
